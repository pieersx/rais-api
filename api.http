###############################################################################
#
# RAIS-API: OAI-PMH 2.0 JSON API - Ejemplos de Uso Completo
#
# Base URL: https://rais.unmsm.edu.pe/api/oai
# O localmente: http://localhost:3000/api/oai
#
# Este archivo contiene ejemplos de todas las operaciones disponibles.
# Usa la extension REST Client (REST Client, Thunder Client, etc.)
#
###############################################################################

###############################################################################
# VERBO 1: IDENTIFY
# Retorna informacion general del repositorio
###############################################################################

### 1.1 - Identificar el repositorio
GET http://localhost:3000/api/oai?verb=Identify

###############################################################################
# VERBO 2: LIST METADATA FORMATS
# Retorna los formatos de metadatos soportados
###############################################################################

### 2.1 - Listar formatos disponibles
GET http://localhost:3000/api/oai?verb=ListMetadataFormats

### 2.2 - Listar formatos para un registro especifico
GET http://localhost:3000/api/oai?verb=ListMetadataFormats&identifier=oai:rais.unmsm.edu.pe:publicacion/34

###############################################################################
# VERBO 3: LIST SETS
# Retorna las categorias (sets) disponibles
###############################################################################

### 3.1 - Listar todos los sets (62 en total)
GET http://localhost:3000/api/oai?verb=ListSets

###############################################################################
# VERBO 4: LIST IDENTIFIERS
# Retorna solo IDs, fechas y categorias (sin metadata completa)
# IDEAL para descubrir que registros existen
###############################################################################

### 4.1 - PAGINA 1: Todos los identificadores (primeros 100)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc

### 4.2 - PAGINA 2: Siguientes 100 identificadores (usa token de 4.1)
# Ejecuta 4.1 primero, copia el resumptionToken y sustituye aqui
GET http://localhost:3000/api/oai?verb=ListIdentifiers&resumptionToken=eyJjdXJzb3IiOjEwMCwic2V0IjpudWxsLCJmcm9tIjpudWxsLCJ1bnRpbCI6bnVsbCwibWV0YWRhdGFQcmVmaXgiOiJvYWlfZGMifQ

###############################################################################
# PUBLICACIONES - Todos los tipos
###############################################################################

### 4.3 - PAGINA 1: Todas las publicaciones (primeros 100 de 59,543)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion

### 4.4 - Articulos: PAGINA 1 (primeros 100 de 26,636)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion:articulo

### 4.5 - Capitulos de libro: PAGINA 1 (primeros 100)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion:capitulo

### 4.6 - Ensayos: PAGINA 1 (primeros 100)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion:ensayo

### 4.7 - Eventos/Ponencias: PAGINA 1 (primeros 100)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion:evento

### 4.8 - Libros: PAGINA 1 (primeros 100)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion:libro

### 4.9 - Tesis: PAGINA 1 (primeros 100)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion:tesis

### 4.10 - Tesis (asesorias): PAGINA 1 (primeros 100)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion:tesis-asesoria

###############################################################################
# PUBLICACIONES - Filtrado por fechas
###############################################################################

### 4.11 - Articulos del 2024: PAGINA 1 (primeros 100 de ~1,530)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion:articulo&from=2024-01-01&until=2024-12-31

### 4.12 - Publicaciones del 2023: PAGINA 1 (primeros 100)
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion&from=2023-01-01&until=2023-12-31

### 4.13 - Publicaciones desde 2020 en adelante: PAGINA 1
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion&from=2020-01-01

### 4.14 - Publicaciones hasta 2015: PAGINA 1
GET http://localhost:3000/api/oai?verb=ListIdentifiers&metadataPrefix=oai_dc&set=publicacion&until=2015-12-31

