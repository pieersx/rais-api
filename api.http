###############################################################################
# VERBO 6: GET RECORD
# Obtiene UN registro especifico por su identificador OAI
# IDEAL para obtener detalles completos de un record conocido
###############################################################################

### 6.1 - Obtener una PUBLICACION especifica (ID: 34)
# Incluye: titulo, autores con ORCID, palabras clave, revista con editorial, 
# bases indexadas, proyectos vinculados, etc.
GET http://localhost:3000/api/oai?verb=GetRecord&identifier=oai:rais.unmsm.edu.pe:publicacion/34&metadataPrefix=oai_dc

### 6.2 - Obtener otro registro de publicacion (ID: 2)
GET http://localhost:3000/api/oai?verb=GetRecord&identifier=oai:rais.unmsm.edu.pe:publicacion/2&metadataPrefix=oai_dc

### 6.3 - Obtener un PROYECTO especifico (ID: 1)
# Incluye: titulo, responsables con ORCID, integrantes, facultad, area OCDE, etc.
GET http://localhost:3000/api/oai?verb=GetRecord&identifier=oai:rais.unmsm.edu.pe:proyecto/1&metadataPrefix=oai_dc

### 6.4 - Obtener una PATENTE especifica (ID: 5)
# Incluye: titulo, inventores con ORCID, oficina presentacion, entidades, etc.
GET http://localhost:3000/api/oai?verb=GetRecord&identifier=oai:rais.unmsm.edu.pe:patente/5&metadataPrefix=oai_dc

###############################################################################
# MANEJO DE PAGINACION - TUTORIAL PASO A PASO
###############################################################################

### PASO 1: Ejecuta esta URL para obtener PAGINA 1
# Verás una respuesta con 100 records y un campo "resumptionToken"
# En la respuesta JSON, busca: "resumptionToken": { "token": "eyJ...", ...}
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc&set=publicacion:articulo

### PASO 2: Copia el valor COMPLETO de "token" (cadena larga que empieza con eyJ)
# Ejemplo del valor que debes copiar:
# eyJjdXJzb3IiOjEwMCwic2V0IjoicHVibGljYWNpb246YXJ0aWN1bG8iLCJmcm9tIjpudWxsLCJ1bnRpbCI6bnVsbCwibWV0YWRhdGFQcmVmaXgiOiJvYWlfZGMifQ

### PASO 3: Sustituye el token en la siguiente URL para obtener PAGINA 2
# Cambia resumptionToken=AQUI_PEGA_EL_TOKEN_QUE_COPIASTE
GET http://localhost:3000/api/oai?verb=ListRecords&resumptionToken=eyJjdXJzb3IiOjEwMCwic2V0IjoicHVibGljYWNpb246YXJ0aWN1bG8iLCJmcm9tIjpudWxsLCJ1bnRpbCI6bnVsbCwibWV0YWRhdGFQcmVmaXgiOiJvYWlfZGMifQ

### PASO 4: Repite PASO 2 y PASO 3 para las siguientes paginas
# Cada vez que ejecutes una URL, obtendrás un nuevo token para la proxima pagina

### PASO 5: Cuando veas resumptionToken.token = "" (cadena vacia)
# Significa que llegaste a la ULTIMA PAGINA - no hay mas registros

###############################################################################
# CAMBIAR TAMAÑO DE PAGINACION
###############################################################################

# El tamaño predeterminado es 100 registros por pagina.
# Para cambiar esto, edita el archivo .env:
#
# PAGE_SIZE=50     -> 50 registros por pagina (mas paginas, menos datos c/u)
# PAGE_SIZE=200    -> 200 registros por pagina (menos paginas, mas datos c/u)
# PAGE_SIZE=1000   -> 1000 registros por pagina (minimo numero de paginas)
#
# Despues de cambiar .env, reinicia el servidor:
# npm run dev     (desarrollo)
# npm start       (produccion)

###############################################################################
# ATAJOS Y TRUCOS
###############################################################################

# Para cosechar TODO sin paginar manualmente, usa curl en terminal:
#
# curl -s "http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc" \
#   | jq '.records[] | .header.identifier' \
#   > ids.txt
#
# O usa el script Python de example en API.md

# Para buscar un identificador en los resultados:
# 1. Ejecuta ListIdentifiers sin filtros
# 2. Copia los primeros IDs que ves
# 3. Usa GetRecord para obtener detalles de uno especifico

###############################################################################
# ESTRUCTURA DE RESPUESTA JSON
###############################################################################

# Cuando ejecutes cualquier URL, obtendrás JSON con esta estructura:
#
# RESPUESTA EXITOSA (sin errores):
# {
#   "responseDate": "2026-03-07T06:00:00.000Z",
#   "request": {
#     "baseURL": "http://localhost:3000/api/oai",
#     "verb": "ListRecords",
#     "metadataPrefix": "oai_dc",
#     "set": "publicacion:articulo"
#   },
#   "verb": "ListRecords",
#   "records": [
#     {
#       "header": {
#         "identifier": "oai:rais.unmsm.edu.pe:publicacion/34",
#         "datestamp": "2023-05-15T10:30:00Z",
#         "setSpec": ["publicacion:articulo"]
#       },
#       "metadata": {
#         "dc:title": "Titulo del articulo",
#         "dc:creator": [{"name": "AUTOR, JUAN", "orcid": "0000-0001-2345-6789"}],
#         "dc:source": "Revista, Editorial: ..., ISSN: ...",
#         ...
#       }
#     }
#     ... (99 records mas)
#   ],
#   "resumptionToken": {
#     "token": "eyJjdXJzb3IiOjEwMCwi...",
#     "completeListSize": 26636,
#     "cursor": 0
#   }
# }
#
# RESPUESTA CON ERROR:
# {
#   "responseDate": "2026-03-07T06:00:00.000Z",
#   "request": {...},
#   "error": {
#     "code": "badVerb",
#     "message": "Illegal OAI verb..."
#   }
# }

###############################################################################
# CODIGOS DE ERROR Y COMO EVITARLOS
###############################################################################

### badVerb: Verbo invalido o faltante
# INCORRECTO (typo en verbo):
GET http://localhost:3000/api/oai?verb=ListRecordss

# CORRECTO:
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc

###############################################################################

### badArgument: Parametro invalido, faltante o no reconocido
# INCORRECTO (ListRecords sin metadataPrefix):
GET http://localhost:3000/api/oai?verb=ListRecords

# CORRECTO:
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc

###############################################################################

### badArgument: Parametro extra no permitido
# INCORRECTO (parametro "extra" no existe en OAI-PMH):
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc&extra=valor

# CORRECTO:
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc

###############################################################################

### idDoesNotExist: Identificador no encontrado
# INCORRECTO (ID que no existe):
GET http://localhost:3000/api/oai?verb=GetRecord&identifier=oai:rais.unmsm.edu.pe:publicacion/999999999&metadataPrefix=oai_dc

# CORRECTO (IDs reales):
GET http://localhost:3000/api/oai?verb=GetRecord&identifier=oai:rais.unmsm.edu.pe:publicacion/34&metadataPrefix=oai_dc

###############################################################################

### noRecordsMatch: Sin resultados para los filtros
# INCORRECTO (fecha futura sin registros):
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc&from=2099-01-01

# CORRECTO (fecha con datos):
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc&from=2024-01-01

###############################################################################

### badResumptionToken: Token invalido o manipulado
# INCORRECTO (token falso):
GET http://localhost:3000/api/oai?verb=ListRecords&resumptionToken=tokeninvalido

# CORRECTO (token valido de una respuesta anterior):
GET http://localhost:3000/api/oai?verb=ListRecords&resumptionToken=eyJjdXJzb3IiOjEwMCwic2V0IjoicHVibGljYWNpb246YXJ0aWN1bG8iLCJmcm9tIjpudWxsLCJ1bnRpbCI6bnVsbCwibWV0YWRhdGFQcmVmaXgiOiJvYWlfZGMifQ

###############################################################################

### cannotDisseminateFormat: Formato de metadatos no soportado
# INCORRECTO (formato no soportado):
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=marc21

# CORRECTO (solo oai_dc soportado):
GET http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc

###############################################################################
# NOTAS IMPORTANTES
###############################################################################

# 1. CAMBIAR BASE URL:
#    - Desarrollo: http://localhost:3000/api/oai
#    - Produccion: https://rais.unmsm.edu.pe/api/oai

# 2. PARAMETROS CON ESPACIOS:
#    Usa %20 en lugar de espacios en la URL
#    Ejemplo: patente:Patente%20de%20invención

# 3. FORMATO DE FECHAS:
#    Usa formato ISO 8601: YYYY-MM-DD
#    Ejemplo: from=2024-01-01&until=2024-12-31

# 4. EXTENSIONES REST CLIENT RECOMENDADAS:
#    - REST Client (VS Code) - la mas recomendada
#    - Thunder Client (VS Code)
#    - Insomnia (multiplataforma)
#    - Postman (multiplataforma)

# 5. USAR CON cURL (Terminal/Bash):
#    curl "http://localhost:3000/api/oai?verb=Identify"
#    curl "http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc&set=publicacion:articulo"

# 6. USAR CON Python (requests):
#    import requests
#    r = requests.get("http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc")
#    print(r.json())

# 7. USAR CON Node.js (fetch):
#    const r = await fetch("http://localhost:3000/api/oai?verb=ListRecords&metadataPrefix=oai_dc");
#    const data = await r.json();
#    console.log(data);

###############################################################################
